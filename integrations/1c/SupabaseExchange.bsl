// Общий модуль 1С: SupabaseОбмен, серверный, экспортный.
// Ключ храните в защищенном месте на сервере 1С.
// Для полного импорта/удаления обычно нужен service_role key.

#Область Настройки

Функция НастройкиSupabase() Экспорт
	Настройки = Новый Структура;
	Настройки.Вставить("Хост", "hdcvntsvaylkmhfarncj.supabase.co");
	Настройки.Вставить("БазовыйПуть", "/rest/v1");
	Настройки.Вставить("Ключ", "ВСТАВЬТЕ_SUPABASE_SERVICE_ROLE_OR_ANON_KEY");
	Возврат Настройки;
КонецФункции

#КонецОбласти

#Область ПубличныйAPI

Функция ЗагрузитьДокументыИнвентаризации() Экспорт
	Путь = "/inventory_documents"
		+ "?select=*,inventory_document_lines(*)"
		+ "&order=date.desc,document_number.desc";
	Возврат ВыполнитьЗапросSupabase("GET", Путь);
КонецФункции

Функция НайтиДокументИнвентаризацииПоНомеру(НомерДокумента) Экспорт
	Путь = "/inventory_documents"
		+ "?select=*"
		+ "&document_number=eq." + КодURL(НомерДокумента)
		+ "&limit=1";

	Ответ = ВыполнитьЗапросSupabase("GET", Путь);
	Если Ответ = Неопределено Или Ответ.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Ответ[0];
КонецФункции

Функция ВыгрузитьОсновныеСредства(МассивОсновныхСредств) Экспорт
	ДопЗаголовки = ЗаголовкиUpsert();
	Возврат ВыполнитьЗапросSupabase(
		"POST",
		"/fixed_assets?on_conflict=id",
		СтрокаJSON(МассивОсновныхСредств),
		ДопЗаголовки
	);
КонецФункции

Функция ВыгрузитьДокументыИнвентаризации(МассивДокументов) Экспорт
	ДопЗаголовки = ЗаголовкиUpsert();
	Возврат ВыполнитьЗапросSupabase(
		"POST",
		"/inventory_documents?on_conflict=document_number",
		СтрокаJSON(МассивДокументов),
		ДопЗаголовки
	);
КонецФункции

Функция ВыгрузитьСтрокиИнвентаризации(МассивСтрок) Экспорт
	ДопЗаголовки = ЗаголовкиUpsert();
	Возврат ВыполнитьЗапросSupabase(
		"POST",
		"/inventory_document_lines?on_conflict=document_id,line_number",
		СтрокаJSON(МассивСтрок),
		ДопЗаголовки
	);
КонецФункции

Функция ОбновитьФактическоеНаличиеСтроки(ИдентификаторСтроки, ФактическиЕсть, ЗначениеШтрихкода = "") Экспорт
	Данные = Новый Структура;
	Данные.Вставить("physically_available", ФактическиЕсть);
	Данные.Вставить("raw_barcode_value", ЗначениеШтрихкода);
	Данные.Вставить("scanned_at", Формат(ТекущаяДата(), "ДФ=yyyy-MM-ddTHH:mm:ss"));

	ДопЗаголовки = Новый Соответствие;
	ДопЗаголовки.Вставить("Prefer", "return=representation");

	Возврат ВыполнитьЗапросSupabase(
		"PATCH",
		"/inventory_document_lines?id=eq." + КодURL(ИдентификаторСтроки),
		СтрокаJSON(Данные),
		ДопЗаголовки
	);
КонецФункции

Функция ЗавершитьИнвентаризацию(НомерДокумента, Завершена = Истина) Экспорт
	Данные = Новый Структура;
	Данные.Вставить("inventory_completed", Завершена);

	ДопЗаголовки = Новый Соответствие;
	ДопЗаголовки.Вставить("Prefer", "return=representation");

	Возврат ВыполнитьЗапросSupabase(
		"PATCH",
		"/inventory_documents?document_number=eq." + КодURL(НомерДокумента),
		СтрокаJSON(Данные),
		ДопЗаголовки
	);
КонецФункции

Функция УдалитьДокументИнвентаризации(НомерДокумента) Экспорт
	// Строки документа удалятся каскадно через foreign key.
	Возврат ВыполнитьЗапросSupabase(
		"DELETE",
		"/inventory_documents?document_number=eq." + КодURL(НомерДокумента)
	);
КонецФункции

Функция УдалитьСтрокуИнвентаризации(ИдентификаторДокумента, ИнвентарныйНомер) Экспорт
	Путь = "/inventory_document_lines"
		+ "?document_id=eq." + КодURL(ИдентификаторДокумента)
		+ "&inventory_number=eq." + КодURL(ИнвентарныйНомер);
	Возврат ВыполнитьЗапросSupabase("DELETE", Путь);
КонецФункции

#КонецОбласти

#Область КонструкторыДанных

Функция ОсновноеСредствоJSON(Код, Наименование) Экспорт
	Данные = Новый Структура;
	Данные.Вставить("id", Код);
	Данные.Вставить("name", Наименование);
	Возврат Данные;
КонецФункции

Функция ДокументИнвентаризацииJSON(
	ДатаДокумента,
	НомерДокумента,
	ИнвентаризацияЗавершена,
	ДанныеВыгруженыВ1С,
	Инвентаризирующий,
	ИИНИнвентаризирующего
) Экспорт
	Данные = Новый Структура;
	Данные.Вставить("date", Формат(ДатаДокумента, "ДФ=yyyy-MM-dd"));
	Данные.Вставить("document_number", НомерДокумента);
	Данные.Вставить("inventory_completed", ИнвентаризацияЗавершена);
	Данные.Вставить("uploaded_to_1c", ДанныеВыгруженыВ1С);
	Данные.Вставить("inventory_officer", Инвентаризирующий);
	Данные.Вставить("inventory_officer_iin", ИИНИнвентаризирующего);
	Возврат Данные;
КонецФункции

Функция СтрокаИнвентаризацииJSON(
	ИдентификаторДокументаSupabase,
	НомерСтроки,
	КодОсновногоСредства,
	НаименованиеОсновногоСредства,
	ИнвентарныйНомер,
	ЕстьВБухгалтерскомУчете,
	ФактическоеНаличие
) Экспорт
	Данные = Новый Структура;
	Данные.Вставить("document_id", ИдентификаторДокументаSupabase);
	Данные.Вставить("line_number", НомерСтроки);
	Данные.Вставить("fixed_asset_id", КодОсновногоСредства);
	Данные.Вставить("fixed_asset_name", НаименованиеОсновногоСредства);
	Данные.Вставить("inventory_number", ИнвентарныйНомер);
	Данные.Вставить("exists_in_accounting", ЕстьВБухгалтерскомУчете);
	Данные.Вставить("physically_available", ФактическоеНаличие);
	Возврат Данные;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ВыполнитьЗапросSupabase(Метод, ПутьРесурса, Тело = Неопределено, ДопЗаголовки = Неопределено) Экспорт
	Настройки = НастройкиSupabase();
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("apikey", Настройки.Ключ);
	Заголовки.Вставить("Authorization", "Bearer " + Настройки.Ключ);
	Заголовки.Вставить("Content-Type", "application/json");
	Заголовки.Вставить("Accept", "application/json");

	Если ДопЗаголовки <> Неопределено Тогда
		Для Каждого Заголовок Из ДопЗаголовки Цикл
			Заголовки.Вставить(Заголовок.Ключ, Заголовок.Значение);
		КонецЦикла;
	КонецЕсли;

	Соединение = Новый HTTPСоединение(
		Настройки.Хост,
		443,
		Неопределено,
		Неопределено,
		Неопределено,
		60,
		Новый ЗащищенноеСоединениеOpenSSL()
	);

	Запрос = Новый HTTPЗапрос(Настройки.БазовыйПуть + ПутьРесурса, Заголовки);
	Если Тело <> Неопределено Тогда
		Запрос.УстановитьТелоИзСтроки(Тело, КодировкаТекста.UTF8);
	КонецЕсли;

	Ответ = Соединение.ВызватьHTTPМетод(Метод, Запрос);
	КодСостояния = Ответ.КодСостояния;
	ТекстОтвета = Ответ.ПолучитьТелоКакСтроку();

	Если КодСостояния < 200 Или КодСостояния >= 300 Тогда
		ВызватьИсключение "Supabase HTTP " + Строка(КодСостояния) + ": " + ТекстОтвета;
	КонецЕсли;

	Если ПустаяСтрока(ТекстОтвета) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат ЗначениеJSON(ТекстОтвета);
КонецФункции

Функция ЗаголовкиUpsert()
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Prefer", "resolution=merge-duplicates,return=representation");
	Возврат Заголовки;
КонецФункции

Функция СтрокаJSON(Значение)
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, Значение);
	Возврат Запись.Закрыть();
КонецФункции

Функция ЗначениеJSON(СтрокаJSON)
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(СтрокаJSON);
	Возврат ПрочитатьJSON(Чтение);
КонецФункции

Функция КодURL(Значение)
	Возврат КодироватьСтроку(Строка(Значение), СпособКодированияСтроки.КодировкаURL);
КонецФункции

#КонецОбласти
